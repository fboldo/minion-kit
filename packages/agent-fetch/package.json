{
	"name": "agent-fetch",
	"version": "0.1.0",
	"description": "Cross-OS URL fetcher for AI agents with a composable plugin architecture",
	"type": "module",
	"main": "./index.ts",
	"bin": {
		"agent-fetch": "./dist/agent-fetch.mjs"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build ./cli.ts --target=node --minify --outfile=dist/agent-fetch.mjs"
	},
	"keywords": [
		"fetch",
		"ai",
		"agent",
		"cli",
		"plugin"
	],
	"license": "MIT",
	"dependencies": {
		"commander": "^13.1.0",
		"fetch-jq": "workspace:*",
		"fetch-json-schema": "workspace:*",
		"fetch-md": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
