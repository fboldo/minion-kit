{
	"name": "minion-kit",
	"type": "module",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@types/bun": "latest",
		"bun-types": "^1.3.11",
		"husky": "^9.1.7"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"format": "biome format --write .",
		"format:staged": "biome check --write --staged --no-errors-on-unmatched",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"build:plugins": "bun run --filter minion-fetch build:oiap",
		"prepare": "husky",
		"precommit": "bun run format:staged && bun run publish:plugins",
		"publish:plugins": "bun run --filter minion-fetch publish:oiap",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"build": "bun run --filter minion-fetch build"
	}
}
